# Copy to ".env" for local dev (never commit .env).

# --- Keep It In The Family form → Google Sheet ---
#
# In Google Apps Script: Deploy → New deployment
#   → Select type: **Web app** (not API executable / add-on / library)
#   → Execute as: **Me**
#   → Who has access: **Anyone**
#   → Deploy → copy the URL ending in /exec
#
VITE_KITF_SUBMIT_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYMENT_ID/exec

# Must match SCRIPT_SECRET in your Apps Script Code.gs (same string in GitHub secret).
VITE_KITF_SUBMIT_SECRET=

# Instagram (optional)
# VITE_INSTAGRAM_WIDGET_URL=
