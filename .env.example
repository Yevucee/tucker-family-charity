# Copy to ".env" for local dev (never commit .env).

# --- Keep It In The Family form → Google Sheet ---
#
# Use TWO different repo secrets — do not swap them:
#   VITE_KITF_SUBMIT_URL   = long https://script.google.com/macros/s/…/exec from Deploy
#   VITE_KITF_SUBMIT_SECRET = short shared password (optional), NOT the URL above
#
# In Google Apps Script: Deploy → New deployment
#   → Select type: **Web app** (not API executable / add-on / library)
#   → Execute as: **Me**
#   → Who has access: **Anyone**
#   → Deploy → copy the URL ending in /exec
#
VITE_KITF_SUBMIT_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_DEPLOYMENT_ID/exec

# Optional; must match SCRIPT_SECRET in Apps Script if you set one there.
VITE_KITF_SUBMIT_SECRET=

# Support Us page — Yoco / PayFast / hosted donation URL (optional).
# VITE_DONATION_LINK=
# Volunteer Google Form or sign-up URL (optional; else email is used).
# VITE_VOLUNTEER_SIGNUP_URL=

# Instagram (optional)
# VITE_INSTAGRAM_WIDGET_URL=
